FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate
WORKDIR /app

# --- deps: устанавливаем зависимости ---
FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json .npmrc ./
COPY apps/web/package.json apps/web/package.json
COPY packages/ai/package.json packages/ai/package.json
RUN pnpm install --frozen-lockfile

# --- builder: собираем проект ---
FROM base AS builder
# Принимаем аргументы сборки (обязательно для Next.js + Payload)
ARG PAYLOAD_SECRET
ARG MONGODB_URI
ARG NEXT_PUBLIC_APP_URL

ENV PAYLOAD_SECRET=$PAYLOAD_SECRET
ENV MONGODB_URI=$MONGODB_URI
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Create .env from build args (.env is in .dockerignore but web build script uses dotenv)
RUN echo "PAYLOAD_SECRET=$PAYLOAD_SECRET" > .env && \
    echo "MONGODB_URI=$MONGODB_URI" >> .env && \
    echo "NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL" >> .env

# Сборка пакетов монорепозитория
RUN pnpm --filter @steam-diploma/ai build 2>/dev/null || true
RUN pnpm --filter web build

# --- runner: запускаем ---
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Копируем только то, что нужно для standalone
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs
EXPOSE 3000

CMD ["node", "apps/web/server.js"]