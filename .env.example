# Database
MONGODB_URI=mongodb://user:pass@host:27017/steam_diploma

# Payload
PAYLOAD_SECRET=your-payload-secret

# Auth.js
AUTH_SECRET=your-auth-secret
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# AI — OpenRouter (primary, paid)
OPENROUTER_API_KEY=sk-or-v1-...
# AI — Gemini (fallback, free tier, comma-separated for key rotation)
GOOGLE_GENERATIVE_AI_API_KEYS=key1,key2,key3

# Usage Tracking (окрема MongoDB для трекінгу токенів)
USAGE_DATABASE_URI=mongodb://user:pass@host:27017/tokens_usage

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PAYLOAD_API_URL=http://localhost:3000/api
NODE_ENV=development
